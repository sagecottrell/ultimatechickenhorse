SettingsManager="*uid://buv1h3breykyb"

[display]

window/stretch/mode="viewport"

[dotnet]

project/assembly_name="ultimatechickenhorse"

[editor_plugins]

enabled=PackedStringArray("res://addons/character-controller/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

[file_customization]

